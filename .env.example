# Bitrix24
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-token/

# App
DEBUG=true

# Secret key for signing JWT tokens (generate: openssl rand -hex 32)
SECRET_KEY=your-secret-key

# JWT token lifetime in minutes (default: 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# PostgreSQL connection string
# Локально задаётся через docker-compose, в проде — через env сервера/Render
# DATABASE_URL=postgresql://bitrix_user:bitrix_pass@db:5432/bitrix_app
